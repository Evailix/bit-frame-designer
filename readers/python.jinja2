
{% if is_cyclical %}
from dataclasses import dataclass
@dataclass
class {{ struct_name }}:
{% for arg in args %}
    {{ arg.name }}: int
{% endfor %}

def {{ function_name }}(data: bytes) -> list[{{ struct_name }}]:
    count = (len(data) - {{ global_padding_bytes }}) // {{ packet_size }}
    result = []

    for i in range(count):
        offset = {{ global_padding_bytes }} + (i * {{ packet_size }})

{% for field in fields %}
        {{ field.name }} = (
{%- for part in field.parts %}
{%- if not loop.first %} |
{% endif %}
            (((data[offset + {{ part.array_index }}] >> {{ part.byte_shift }}) & {{ part.mask }}) << {{ part.val_shift }})
{%- endfor %}
        )
{% endfor %}

        result.append(
            {{ struct_name }}(
{% for arg in args %}
                {{ arg.name }}={{ arg.name }}{{ "," if not loop.last }}
{% endfor %}
            )
        )

    return result

{% else %}

def {{ function_name }}(data: bytes) -> dict:
{% for field in fields %}
    {{ field.name }} = (
{%- for part in field.parts %}
{%- if not loop.first %} |
{% endif %}
        (((data[{{ global_padding_bytes + part.array_index }}] >> {{ part.byte_shift }}) & {{ part.mask }}) << {{ part.val_shift }})
{%- endfor %}
    )

{% endfor %}

    return {
{% for arg in args %}
        "{{ arg.name }}": {{ arg.name }}{{ "," if not loop.last }}
{% endfor %}
    }

{% endif %}
